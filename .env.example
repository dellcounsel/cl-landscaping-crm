# ---------------------------------------------------------------------------
# FieldBook environment variables. Copy to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.
# ---------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key BYPASSES RLS — server-only, keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (used for public links, OAuth redirect base, emails)
APP_URL=http://localhost:3000

# Resend (email) — Milestone 2. If RESEND_API_KEY is blank, the app still works:
# quotes produce a shareable public link; email sending is simply skipped.
RESEND_API_KEY=
# From address. Until you verify a domain in Resend, leave this as the shared
# testing sender (which can only email your own Resend account address).
# After verifying a domain, set e.g. "Dellavalle Landscaping <quotes@yourdomain.com>".
EMAIL_FROM=FieldBook <onboarding@resend.dev>
# Business name shown on quotes and emails.
BUSINESS_NAME=FieldBook
# Where to send "client approved/declined a quote" notifications (your email).
OWNER_NOTIFY_EMAIL=

# Google Calendar OAuth — added in Milestone 4
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback

# 32-byte key (base64) for encrypting the stored Google refresh token (M4).
# Generate with:  openssl rand -base64 32
ENCRYPTION_KEY=

# Shared secret required by Vercel Cron routes (M3+). Generate any random string.
CRON_SECRET=

# Used only by `npm run seed` to create your first owner login + demo data.
SEED_OWNER_EMAIL=you@example.com
SEED_OWNER_PASSWORD=change-me-strong-password
SEED_OWNER_NAME=Your Name
